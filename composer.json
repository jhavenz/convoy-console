{
    "name": "convoy/console",
    "description": "CLI application framework for Convoy",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.4",
        "convoy/core": "^1.0"
    },
    "require-dev": {
        "clue/docker-react": "^1.6"
    },
    "suggest": {
        "convoy/stream": "For streaming data through console commands",
        "convoy/parallel": "For worker process parallelism in CLI tasks"
    },
    "autoload": {
        "psr-4": {
            "Convoy\\Console\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Convoy\\Console\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
